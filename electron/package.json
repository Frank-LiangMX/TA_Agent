{
  "name": "tagent-desktop",
  "version": "0.27.0",
  "description": "TAgent - 游戏技术美术 AI Agent 桌面应用",
  "main": "main.js",
  "scripts": {
    "start": "node scripts/start-electron.js",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "author": "TA Agent Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^39.5.1",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.tagent.desktop",
    "productName": "TAgent",
    "directories": {
      "output": "../dist/electron-release"
    },
    "files": [
      "main.js",
      "preload.js",
      "dist/**/*"
    ],
    "extraResources": [
      {
        "from": "../dist/TAgent",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TAgent",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "installerLanguages": [
        2052
      ],
      "language": "2052",
      "unicode": true
    }
  },
  "dependencies": {
    "qrcode": "^1.5.4"
  }
}
